# Optional environment overrides for portability / CI
#
# If set, this path overrides --config default.
# QA_PIPELINE_CONFIG=./config.local.yaml
#
# acli.exe path (recommended for machines where it's not on PATH)
# QA_PIPELINE_ACLI_PATH=C:\path\to\acli.exe
#
# Token file path (if your acli setup uses a token file)
# QA_PIPELINE_ACLI_TOKEN_PATH=C:\path\to\token.txt
#
# Atlassian metadata (optional)
# QA_PIPELINE_ACLI_SITE=your-domain.atlassian.net
# QA_PIPELINE_ACLI_EMAIL=you@company.com
#
# Output base dir (defaults to ./output)
# QA_PIPELINE_OUTPUT_DIR=./output

